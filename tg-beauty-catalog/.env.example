# ============================================================
# BeautyCatalog — переменные окружения (ШАБЛОН)
# Это шаблон — безопасно хранить в git.
# Настоящие значения — только в .env (в git НЕ попадает).
# ============================================================

# --- Supabase (Project Settings → Data → API) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...anon_key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key...

# Прямое подключение к PostgreSQL для SQLAlchemy
# (Project Settings → Data → Database → Connection string → URI mode)
DATABASE_URL=postgresql+asyncpg://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# --- Telegram ---
# Твой числовой Telegram ID (узнать через @userinfobot)
ADMIN_TELEGRAM_USER_ID=123456789

# Токен платформенного бота @YourPlatformBot (получить у @BotFather)
PLATFORM_BOT_TOKEN=1234567890:AAH...

# --- Шифрование токенов ботов мастеров ---
# Сгенерировать один раз:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-32-byte-base64-fernet-key=

# --- Файловое хранилище Cloudflare R2 (заполнить позже) ---
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=beauty-catalog
R2_PUBLIC_URL=https://your-r2-public-domain.com

# --- Настройки приложения ---
ENVIRONMENT=development
API_BASE_URL=http://localhost:8000
MINI_APP_BASE_URL=https://your-mini-app-domain.com
